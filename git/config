	email = jackscmail@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub
[core]
	editor = nvim
	excludesfile = ~/.config/git/.gitignore_global
[init]
	defaultBranch = main
[status]
	submoduleSummary = true
[pull]
	rebase = false
[credential]
	helper = osxkeychain
[gpg]
	format = ssh
[commit]
	gpgsign = true
